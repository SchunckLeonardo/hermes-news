{
  "info": {
    "_postman_id": "b77cb705-ad8d-4e84-ad04-73f808170423",
    "name": "Hermes News",
    "description": "Local smoke tests for Hermes News, the conversational webhook and the local Evolution API container.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.environment.set('request_guid', pm.variables.replaceIn('{{$guid}}'));",
          "pm.environment.set('request_timestamp', pm.variables.replaceIn('{{$timestamp}}'));",
          "pm.environment.set('request_iso_timestamp', pm.variables.replaceIn('{{$isoTimestamp}}'));",
          "pm.environment.set('request_random_int', pm.variables.replaceIn('{{$randomInt}}'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Hermes News API",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/actuator/health",
              "host": ["{{base_url}}"],
              "path": ["actuator", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('health is UP', function () { pm.expect(pm.response.json().status).to.eql('UP'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Send Daily Digest",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/digests/send-daily",
              "host": ["{{base_url}}"],
              "path": ["api", "digests", "send-daily"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 202', function () { pm.response.to.have.status(202); });",
                  "const body = pm.response.json();",
                  "pm.test('response contains article count', function () { pm.expect(body).to.have.property('articleCount'); });",
                  "pm.test('response contains WhatsApp status', function () { pm.expect(body.whatsAppStatus).to.be.oneOf(['SENT', 'SKIPPED', 'FAILED']); });",
                  "if (body.message) { pm.environment.set('last_digest_message', body.message); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Digest Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/actuator/metrics/hermes.digest.runs",
              "host": ["{{base_url}}"],
              "path": ["actuator", "metrics", "hermes.digest.runs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('digest metric is exposed', function () { pm.expect(body.name).to.eql('hermes.digest.runs'); pm.expect(body.measurements).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "List News Sources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/news-sources",
              "host": ["{{base_url}}"],
              "path": ["api", "news-sources"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('response is an array', function () { pm.expect(body).to.be.an('array'); });",
                  "if (body.length > 0 && body[0].url) { pm.environment.set('source_url', body[0].url); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Add RSS Source",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{source_url}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/news-sources/rss",
              "host": ["{{base_url}}"],
              "path": ["api", "news-sources", "rss"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.test('source has url and status', function () { pm.expect(body).to.have.property('url'); pm.expect(body).to.have.property('status'); });",
                  "pm.environment.set('source_url', body.url);"
                ]
              }
            }
          ]
        },
        {
          "name": "Rename RSS Source",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{source_url}}\",\n  \"name\": \"{{source_label}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/news-sources/label",
              "host": ["{{base_url}}"],
              "path": ["api", "news-sources", "label"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('source label updated', function () { pm.expect(body.name).to.eql(pm.environment.get('source_label')); });",
                  "pm.environment.set('source_url', body.url);"
                ]
              }
            }
          ]
        },
        {
          "name": "Test RSS Source",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{source_url}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/news-sources/test",
              "host": ["{{base_url}}"],
              "path": ["api", "news-sources", "test"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('test result has success flag', function () { pm.expect(body).to.have.property('success'); });",
                  "pm.test('test result has message', function () { pm.expect(body).to.have.property('message'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Disable RSS Source",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{source_url}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/news-sources/disable",
              "host": ["{{base_url}}"],
              "path": ["api", "news-sources", "disable"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('source disabled', function () { pm.expect(pm.response.json().enabled).to.eql(false); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Enable RSS Source",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{source_url}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/news-sources/enable",
              "host": ["{{base_url}}"],
              "path": ["api", "news-sources", "enable"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('source enabled', function () { pm.expect(pm.response.json().enabled).to.eql(true); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Receive WhatsApp Webhook (Record Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"messages.upsert\",\n  \"instance\": \"{{evolution_instance}}\",\n  \"requestId\": \"{{request_guid}}\",\n  \"timestamp\": \"{{request_timestamp}}\",\n  \"createdAt\": \"{{request_iso_timestamp}}\",\n  \"data\": {\n    \"key\": {\n      \"id\": \"{{$guid}}\",\n      \"remoteJid\": \"5511999999999@s.whatsapp.net\",\n      \"fromMe\": true\n    },\n    \"message\": {\n      \"conversation\": \"Postman webhook smoke {{$randomInt}}\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/whatsapp/webhook",
              "host": ["{{base_url}}"],
              "path": ["api", "whatsapp", "webhook"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 202', function () { pm.response.to.have.status(202); });",
                  "pm.test('webhook accepted', function () { pm.expect(pm.response.json().status).to.eql('accepted'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "WhatsApp Agent Commands (Real Reply)",
          "description": "These webhook requests call the conversational agent and may send a real WhatsApp reply. Set agent_remote_jid to the authorized sender JID before running them.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('agent_remote_jid')) {",
                  "  console.warn('Set agent_remote_jid before running conversational agent requests.');",
                  "  pm.execution.skipRequest();",
                  "}"
                ]
              }
            }
          ],
          "item": [
            {
              "name": "Explain Digest Item",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"event\": \"messages.upsert\",\n  \"instance\": \"{{evolution_instance}}\",\n  \"data\": {\n    \"key\": {\n      \"id\": \"{{$guid}}\",\n      \"remoteJid\": \"{{agent_remote_jid}}\",\n      \"fromMe\": false\n    },\n    \"message\": {\n      \"conversation\": \"por que a noticia {{digest_item_number}} foi selecionada?\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/whatsapp/webhook",
                  "host": ["{{base_url}}"],
                  "path": ["api", "whatsapp", "webhook"]
                }
              },
              "event": [{
                "listen": "test",
                "script": { "type": "text/javascript", "exec": ["pm.test('webhook accepted', function () { pm.response.to.have.status(202); });"] }
              }]
            },
            {
              "name": "Positive Digest Feedback",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"event\": \"messages.upsert\",\n  \"instance\": \"{{evolution_instance}}\",\n  \"data\": {\n    \"key\": {\n      \"id\": \"{{$guid}}\",\n      \"remoteJid\": \"{{agent_remote_jid}}\",\n      \"fromMe\": false\n    },\n    \"message\": {\n      \"conversation\": \"gostei da noticia {{digest_item_number}}\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/whatsapp/webhook",
                  "host": ["{{base_url}}"],
                  "path": ["api", "whatsapp", "webhook"]
                }
              },
              "event": [{
                "listen": "test",
                "script": { "type": "text/javascript", "exec": ["pm.test('webhook accepted', function () { pm.response.to.have.status(202); });"] }
              }]
            },
            {
              "name": "Add Urgent Watch",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"event\": \"messages.upsert\",\n  \"instance\": \"{{evolution_instance}}\",\n  \"data\": {\n    \"key\": {\n      \"id\": \"{{$guid}}\",\n      \"remoteJid\": \"{{agent_remote_jid}}\",\n      \"fromMe\": false\n    },\n    \"message\": {\n      \"conversation\": \"monitore {{watchlist_term}}\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/whatsapp/webhook",
                  "host": ["{{base_url}}"],
                  "path": ["api", "whatsapp", "webhook"]
                }
              },
              "event": [{
                "listen": "test",
                "script": { "type": "text/javascript", "exec": ["pm.test('webhook accepted', function () { pm.response.to.have.status(202); });"] }
              }]
            },
            {
              "name": "Search Weekly History",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"event\": \"messages.upsert\",\n  \"instance\": \"{{evolution_instance}}\",\n  \"data\": {\n    \"key\": {\n      \"id\": \"{{$guid}}\",\n      \"remoteJid\": \"{{agent_remote_jid}}\",\n      \"fromMe\": false\n    },\n    \"message\": {\n      \"conversation\": \"o que saiu sobre {{history_query}} esta semana?\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/whatsapp/webhook",
                  "host": ["{{base_url}}"],
