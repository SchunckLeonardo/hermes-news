          ]
        }
      ]
    },
    {
      "name": "Evolution API Local",
      "item": [
        {
          "name": "Evolution Root",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "apikey",
                "value": "{{evolution_api_key}}"
              }
            ],
            "url": {
              "raw": "{{evolution_base_url}}",
              "host": ["{{evolution_base_url}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Evolution responds', function () { pm.expect(pm.response.code).to.be.oneOf([200, 301, 302, 404]); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Send Text Through Evolution",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "apikey",
                "value": "{{evolution_api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"{{evolution_recipient}}\",\n  \"text\": \"Hermes News Postman smoke {{$timestamp}} / {{$guid}}\"\n}"
            },
            "url": {
              "raw": "{{evolution_base_url}}/message/sendText/{{evolution_instance}}",
              "host": ["{{evolution_base_url}}"],
              "path": ["message", "sendText", "{{evolution_instance}}"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('evolution_recipient')) {",
                  "  console.warn('Set evolution_recipient before sending a real WhatsApp message.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Evolution send endpoint responded', function () { pm.expect(pm.response.code).to.be.below(500); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
